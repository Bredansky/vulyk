{
  "name": "vulyk",
  "version": "0.3.0",
  "description": "Package manager for AI agent skills and agents",
  "keywords": [
    "ai",
    "agents",
    "skills",
    "claude",
    "opencode",
    "codex"
  ],
  "license": "MIT",
  "author": "bredansky",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "bin": {
    "vulyk": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc",
    "dev": "tsx src/index.ts",
    "fix": "eslint . --fix --cache",
    "lint": "eslint . --cache",
    "prepare": "husky",
    "start": "node dist/index.js"
  },
  "lint-staged": {
    "!(*.ts|*.mts|*.cts|*.js|*.cjs|*.mjs)": "prettier --write --ignore-unknown",
    "*.ts|*.mts|*.cts|*.js|*.cjs|*.mjs": "eslint --fix --max-warnings 0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "zirka": "^0.0.27"
  }
}
